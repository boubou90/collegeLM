---
import ClassLayout from '../../../layouts/ClassLayout.astro';
import ActivitySection from '../../../components/ActivitySection.astro';
import BackButton from '../../../components/BackButton.astro';

const documents = [
  {
    title: "Ressources",
    pdfUrl: "/documents/5eme/sequence-6/activite-4/Fiche-ressource-criteres.pdf"
  }
];
---

<ClassLayout title="Activité 4 - Séquence 6 - 5ème" level="5eme">
  <BackButton href="/5eme/sequence-6" />
  <h1>Activité 4 - Ressources</h1>
  
  <ActivitySection
    title="Fiche ressource Activité 3 Critères 5emes "
    description="Caractériser et choisir un objet ou un système technique selon différents critères."
    documents={documents}
    activityNumber={4}
    totalActivities={4}
    sequenceHref="/5eme/sequence-6"
    sequenceLabel="Séquence 6 — Choisir un OST"
    retenir={{
      definitions: [
        { term: "Fiche technique (datasheet)", def: "Document officiel du fabricant listant toutes les caractéristiques mesurables d'un produit." },
        { term: "Label énergie", def: "Étiquette normalisée (A+++ à G) indiquant la classe d'efficacité énergétique d'un appareil électrique." },
      ],
      points: [
        "Fiche ressource Critères disponible dans les ressources de cette séquence.",
        "Utiliser les fiches techniques pour remplir les tableaux comparatifs des activités 1 à 3.",
      ],
    }}
  >
    <div class="activity-content">
      <h3>Bilan — Choisir un OST selon des critères</h3>
      <p>Cette séquence t'a appris à analyser et comparer des objets techniques selon des critères objectifs. Cette méthode s'applique à tout achat ou choix technologique : pas seulement les ampoules, mais aussi les téléphones, ordinateurs, appareils électroménagers...</p>

      <h3>La démarche de choix d'un OST</h3>
      <ol>
        <li><strong>Analyser le besoin</strong> : quelle fonction doit remplir l'objet ? Dans quel contexte ?</li>
        <li><strong>Identifier les critères pertinents</strong> : fonctionnel, économique, environnemental, sécurité.</li>
        <li><strong>Collecter les données</strong> : fiches techniques, mesures, étiquettes énergie.</li>
        <li><strong>Comparer dans un tableau</strong> : mettre en regard les valeurs pour chaque critère.</li>
        <li><strong>Décider</strong> : choisir le meilleur compromis selon les priorités.</li>
        <li><strong>Justifier</strong> : expliquer le choix en s'appuyant sur le tableau comparatif.</li>
      </ol>

      <h3>L'étiquette énergie européenne</h3>
      <p>L'étiquette énergie (classes A à G, anciennement A+++ à G) permet une comparaison rapide des appareils électriques. Elle indique :</p>
      <ul>
        <li>La classe d'efficacité énergétique (A = le plus efficace).</li>
        <li>La consommation annuelle en kWh (pour les réfrigérateurs, lave-linge...).</li>
        <li>D'autres critères spécifiques (bruit, capacité, durée de vie des lampes...).</li>
      </ul>

      <h3>Fiche ressource — Critères de choix</h3>
      <p>La fiche ressource disponible dans cette activité récapitule les critères standards pour comparer des objets techniques, avec des exemples d'application à différents OST. Elle est un outil de référence pour les activités d'analyse fonctionnelle et de choix technique.</p>
    </div>
  </ActivitySection>
</ClassLayout>

<style>
  h1 {
    text-align: center;
    color: #1e3a8a;
    margin-bottom: 2rem;
  }
</style>
