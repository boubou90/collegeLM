  {
    title: "Les différentes formes d’énergie : électrique, cinétique, potentielle, thermique, lumineuse (rayonnement)",
    pdfUrl: "/documents/4eme/sequence-5/SFC1a-les-differentes-formes-denergie-_-electrique-cinetique-potentielle-thermique-lumineuse-rayonnement.pdf"
  },
  {
    title: "Les conversions d’énergie des constituants suivants : moteur électrique, lampe, radiateur, génératrice, vérin",
    pdfUrl: "/documents/4eme/sequence-5/SFC1b-les-conversions-denergie-des-constituants-suivants-_-moteur-electrique-lampe-radiateur-generatrice-verin.pdf"
  },
  {
