---
import ClassLayout from '../../../layouts/ClassLayout.astro';
import ActivitySection from '../../../components/ActivitySection.astro';
import BackButton from '../../../components/BackButton.astro';

const documents = [
  {
    title: "Documents ressources - Activite 2 reseau classe techno",
    pdfUrl: "/documents/4eme/sequence-7/activite2_reseau_classe_techno.fls"
  },
  {
    title: "Documents ressources - Activite 3 reseau classe techno",
    pdfUrl: "/documents/4eme/sequence-7/activite3_reseau_classe_techno.fls"
  },
  {
    title: "Documents ressources - Resources filius",
    pdfUrl: "/documents/4eme/sequence-7/Resources filius.pdf"
  }
];
---

<ClassLayout title="Documents ressources - Séquence 7 - 4ème" level="4eme">
  <BackButton href="/4eme/sequence-7" />
  <h1>Documents resources</h1>
  
  <ActivitySection
    title="Documents ressources - Séquence 7"
    description="Documents ressources à exploiter pour bien répondre aux questions de l'activité."
    documents={documents}
    activityNumber={4}
    totalActivities={4}
    sequenceHref="/4eme/sequence-7"
    sequenceLabel="Séquence 7 — Réseau local WiFi"
    retenir={{
      definitions: [
        { term: "Documentation réseau", def: "Ensemble des fiches et schémas décrivant l'architecture, l'adressage et la configuration d'un réseau." },
      ],
      points: [
        "Fiches réseau et tutoriels de configuration IP disponibles dans les ressources.",
        "Synthèse de la séquence : schéma du réseau, plan d'adressage, test de connectivité.",
      ],
    }}
  >
    <div class="activity-content">
      <h3>Filius : simuler un réseau informatique</h3>
      <p>
        <strong>Filius</strong> est un logiciel gratuit et open-source de simulation de réseaux informatiques. Il permet de créer virtuellement des réseaux (switches, routeurs, ordinateurs, serveurs) et de les configurer sans avoir besoin de matériel réel. C'est un outil pédagogique idéal pour comprendre l'adressage IP, les protocoles de communication et le routage, avant de les mettre en œuvre sur le réseau réel.
      </p>

      <h3>Les ressources Filius de la séquence</h3>
      <p>
        Les fichiers <strong>.fls</strong> (extension Filius) fournis en ressource contiennent des réseaux pré-configurés correspondant aux activités 2 et 3. On peut les ouvrir dans Filius pour visualiser l'architecture du réseau, modifier les adresses IP, tester la connectivité par ping et observer le cheminement des paquets de données entre les équipements.
      </p>

      <h3>Schéma d'un réseau : comment le représenter</h3>
      <p>
        Un schéma réseau utilise des symboles standardisés : ordinateur (écran), switch (boîtier avec plusieurs ports), routeur (cercle avec flèches), borne WiFi (antenne), serveur (tour). Les connexions filaires sont représentées par des lignes pleines, le WiFi par des lignes ondulées. Chaque équipement est annoté avec son adresse IP et son nom.
      </p>

      <h3>Synthèse de la séquence réseau</h3>
      <p>
        À l'issue de la séquence, vous devez être capables de : lire et compléter un plan d'adressage IP, configurer une adresse IP statique sur un ordinateur Windows, tester la connectivité avec la commande ping, et représenter l'architecture d'un réseau local mixte filaire/WiFi sur un schéma.
      </p>
    </div>
  </ActivitySection>
</ClassLayout>

<style>
  h1 {
    text-align: center;
    color: #1e3a8a;
    margin-bottom: 2rem;
  }
</style>
